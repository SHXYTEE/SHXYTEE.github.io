std := import('std')
fs := import('fs')

Virtual := import('Virtual')

{ s: s } := import('ywx/s')

// ---
// @ Initial

client := fs.readFile('client.mbc')

vm := Virtual.createStandardVM()

vm.registerBuiltin('document', document)
vm.registerBuiltin('window', window)

with vm.runChunk(client) {
	debug: true
	onDone: fn() '[client-preload] VM finished' |> s() |> window.console.log()
}