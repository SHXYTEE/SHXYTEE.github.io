{ lorem: lorem } := import('ywx/lorem')

{ s: s } := import('ywx/s')

{ tag: tag } := import('ywx/tag')
{ Router: Router } := import('ywx/router')

{ Router: HttpRouter } := import('http')

// ---
// @ Pages

home := import('ywx/y.home')

// ---

with document.addEventListener('DOMContentLoaded') fn {
    r := with Router() {
        '/': home.render
        '/404': fn(params, ctx) with ctx.appendChild() tag(:p, 'Page not found')
    }
    if r != ? -> document.body.appendChild(r)
}